NODE_ENV=development
PORT=8080
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=15m

# If using Groq (OpenAI-compatible endpoint)
GROQ_API_KEY=replace-with-your-groq-api-key
# Examples: llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-70b-versatile

# Weather-aware feature (Open-Meteo is free, no key needed)

